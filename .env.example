# Riot Games API key (https://developer.riotgames.com/)
RIOT_API_KEY=your_riot_api_key

# PostgreSQL connection for Conqueror (match deduplication)
CONQUEROR_DATABASE_URL=postgresql://user:password@host:5432/conqueror
# Or use DATABASE_URL if Railway provides it
# DATABASE_URL=postgresql://...

# Meeps backend URL
MEEPS_API_URL=https://meeps-backend.railway.app

# Shared secret for Conqueror → Meeps API auth (X-Conqueror-Secret header)
CONQUEROR_WEBHOOK_SECRET=your_webhook_secret

# Poll interval in ms (default: 60000 = 1 min)
POLL_INTERVAL_MS=60000

# HTTP server port (default: 3000)
PORT=3000

# CORS allowed origin for Meeps frontend (default: *). Set to your Meeps frontend URL, e.g. https://meeps.example.com
# CORS_ORIGIN=https://meeps.example.com
