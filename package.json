{
  "name": "conqueror",
  "version": "1.0.0",
  "description": "TFT match tracker for Meeps - polls Riot API and posts to Meeps",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "echo 'Run: psql $CONQUEROR_DATABASE_URL -f src/db/schema.sql'"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "twisted": "^1.72.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
